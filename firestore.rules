rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function eventDoc(eventId) {
      return /databases/$(database)/documents/events/$(eventId);
    }

    function isEventMember(eventId) {
      return isSignedIn() &&
        get(eventDoc(eventId)).data.memberIds.hasAny([request.auth.uid]);
    }

    function isEventCreatorAfterWrite(eventId) {
      return isSignedIn() &&
        getAfter(eventDoc(eventId)).data.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /events/{eventId} {
      allow read: if isSignedIn() &&
        resource.data.memberIds.hasAny([request.auth.uid]);
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isEventMember(eventId);

      match /members/{memberId} {
        allow read: if isEventMember(eventId);
        allow create: if isEventMember(eventId) || (
          request.auth.uid == memberId && isEventCreatorAfterWrite(eventId)
        );
        allow update, delete: if isEventMember(eventId);
      }

      match /guests/{guestId} {
        allow read, write: if isEventMember(eventId);
      }
    }
  }
}
